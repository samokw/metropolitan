# STATCAN_LABOUR_PUMF_AUTO_HIST_MIN_YEAR=2020
# STATCAN_LABOUR_PUMF_MIN_REFERENCE=2025-01
# STATCAN_LABOUR_PUMF_SKIP_UNCHANGED=true
# STATCAN_LABOUR_PUMF_SYNC_STATE_FILE=pumf_wave_sync.json
