# Run ingestion pipeline daily at midnight
0 0 * * * echo "[$(date)] Starting pipeline run" >> /var/log/cron.log && cd /usr/app && PYTHONPATH=/usr/app /usr/local/bin/python /usr/app/src/DataIngester.py >> /var/log/cron.log 2>&1
# An empty line is required at the end of this file for a valid cron file.
