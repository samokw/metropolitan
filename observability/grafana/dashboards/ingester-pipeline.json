        },
        "overrides": []
      }
    },
    {
      "title": "Data Loaded (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "MariaDB",
      "targets": [
        {
          "rawSql": "SELECT run_at AS time, estimated_bytes_loaded AS 'Housing' FROM pipeline_runs WHERE source = 'housing' ORDER BY run_at",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT run_at AS time, estimated_bytes_loaded AS 'Labour' FROM pipeline_runs WHERE source = 'labour' ORDER BY run_at",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": {
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 6
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Latest Pipeline Runs",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": "MariaDB",
      "targets": [
        {
          "rawSql": "SELECT run_at AS 'Time', source AS 'Source', records_extracted AS 'Extracted', records_transformed AS 'Transformed', records_loaded AS 'Loaded', records_rejected AS 'Rejected', CONCAT(ROUND(bytes_downloaded / 1048576, 2), ' MB') AS 'Downloaded', CONCAT(ROUND(estimated_bytes_loaded / 1048576, 2), ' MB') AS 'Written', CONCAT(success_rate_pct, '%') AS 'Success Rate', CONCAT(duration_seconds, 's') AS 'Duration', error_count AS 'Errors' FROM pipeline_runs ORDER BY run_at DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "title": "Total Records Loaded (All Time)",
