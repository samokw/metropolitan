  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Records Loaded per Run",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "MariaDB",
      "targets": [
        {
          "rawSql": "SELECT run_at AS time, records_loaded AS 'Loaded', records_rejected AS 'Rejected', source FROM pipeline_runs ORDER BY run_at",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Rejected" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Loaded" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "title": "Data Volume Downloaded",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "MariaDB",
      "targets": [
        {
          "rawSql": "SELECT run_at AS time, bytes_downloaded AS 'Housing' FROM pipeline_runs WHERE source = 'housing' ORDER BY run_at",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT run_at AS time, bytes_downloaded AS 'Labour' FROM pipeline_runs WHERE source = 'labour' ORDER BY run_at",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": {
            "fillOpacity": 10,
            "pointSize": 6,
            "drawStyle": "line",
            "showPoints": "always"
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Success Rate Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "MariaDB",
      "targets": [
        {
          "rawSql": "SELECT run_at AS time, success_rate_pct AS 'Housing' FROM pipeline_runs WHERE source = 'housing' ORDER BY run_at",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT run_at AS time, success_rate_pct AS 'Labour' FROM pipeline_runs WHERE source = 'labour' ORDER BY run_at",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          },
          "custom": {
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 6,
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Pipeline Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "MariaDB",
      "targets": [
        {
          "rawSql": "SELECT run_at AS time, duration_seconds AS 'Housing' FROM pipeline_runs WHERE source = 'housing' ORDER BY run_at",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT run_at AS time, duration_seconds AS 'Labour' FROM pipeline_runs WHERE source = 'labour' ORDER BY run_at",
          "format": "time_series",
          "refId": "B"
