      },
      "targets": [
        {
          "format": "table",
          "refId": "A",
          "rawSql": "SELECT run_at AS 'Time', source AS 'Source', COALESCE(strategy, 'bulk') AS 'Strategy', records_extracted AS 'Extracted', records_loaded AS 'Loaded', records_rejected AS 'Rejected', ROUND(bytes_downloaded / 1048576, 2) AS 'Downloaded MB', ROUND(estimated_bytes_loaded / 1048576, 2) AS 'Written MB', success_rate_pct AS 'Success %', duration_seconds AS 'Duration s', error_count AS 'Errors' FROM pipeline_runs WHERE run_at BETWEEN UTC_TIMESTAMP() - INTERVAL 30 DAY AND UTC_TIMESTAMP() ORDER BY run_at DESC LIMIT 25"
