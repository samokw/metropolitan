    {
      "title": "Errors per Run",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "MariaDB",
      "targets": [
        {
          "rawSql": "SELECT run_at AS time, error_count AS 'Housing' FROM pipeline_runs WHERE source = 'housing' ORDER BY run_at",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT run_at AS time, error_count AS 'Labour' FROM pipeline_runs WHERE source = 'labour' ORDER BY run_at",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
